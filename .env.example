# ===========================================
# Nonprofit Treasurer App - Environment Config
# ===========================================

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret

# --- Google Sheets ---
# The ID of the Google Spreadsheet used as the database
# Found in the URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id

# --- Google Service Account (for server-side Sheets/Drive access) ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="your_private_key_here"

# --- Vercel Blob (Receipt Uploads) ---
# Get this from Vercel Dashboard → Storage → Create Blob Store
BLOB_READ_WRITE_TOKEN=

# --- Square API (Read-Only) ---
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=your_square_location_id

# --- PayPal API (Read-Only) ---
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENVIRONMENT=sandbox

# --- Telemetry - Sentry (Error Monitoring) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Telemetry - Google Analytics 4 ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- App Config ---
# Comma-separated list of admin emails
ADMIN_EMAILS=admin@example.com
# Comma-separated list of treasurer emails
TREASURER_EMAILS=treasurer@example.com
# Financial year start month (1 = January)
FINANCIAL_YEAR_START_MONTH=1

# --- Database (Neon Postgres) ---
# DATABASE_URL is set per-environment in separate files (NOT in .env.local):
#
#   .env.development.local → Neon DEV branch (local dev + Prisma CLI)
#   .env.production.local  → Neon PROD branch (local prod build)
#   Vercel env vars        → set per-environment in Vercel dashboard
#
# Next.js auto-loads the right file:
#   next dev   → .env.development.local
#   next build → .env.production.local
#
# Prisma CLI loads .env.development.local via prisma.config.ts.
# To run migrations against prod: DATABASE_URL="prod-url" npx prisma migrate deploy
#
# Example:
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
