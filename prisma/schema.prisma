generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Member {
  id                 String   @id @default(cuid())
  firstName          String   @default("")
  middleName         String   @default("")
  lastName           String   @default("")
  email              String   @default("")
  phone              String   @default("")
  homePhone          String   @default("")
  cellPhone          String   @default("")
  qualifyingDegree   String   @default("")
  nativePlace        String   @default("")
  college            String   @default("")
  jobTitle           String   @default("")
  employer           String   @default("")
  specialInterests   String   @default("")
  submissionId       String   @default("")
  membershipType     String   @default("Yearly")
  membershipLevel    String   @default("")
  registrationDate   String   @default("")
  renewalDate        String   @default("")
  status             String   @default("Active")
  notes              String   @default("")
  loginEmail         String   @default("")
  createdAt          String   @default("")
  updatedAt          String   @default("")

  addresses      MemberAddress[]
  spouses        MemberSpouse[]
  children       MemberChild[]
  memberships    MemberMembership[]
  payments       MemberPayment[]
  sponsors       MemberSponsor[]
  participations EventParticipant[]

  @@index([email])
  @@index([loginEmail])
  @@index([status])
  @@map("members")
}

model MemberAddress {
  id        String @id @default(cuid())
  memberId  String
  street    String @default("")
  street2   String @default("")
  city      String @default("")
  state     String @default("")
  zipCode   String @default("")
  country   String @default("")
  createdAt String @default("")
  updatedAt String @default("")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("member_addresses")
}

model MemberSpouse {
  id               String @id @default(cuid())
  memberId         String
  firstName        String @default("")
  middleName       String @default("")
  lastName         String @default("")
  email            String @default("")
  phone            String @default("")
  nativePlace      String @default("")
  company          String @default("")
  college          String @default("")
  qualifyingDegree String @default("")
  createdAt        String @default("")
  updatedAt        String @default("")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([email])
  @@map("member_spouses")
}

model MemberChild {
  id          String @id @default(cuid())
  memberId    String
  name        String @default("")
  sex         String @default("")
  grade       String @default("")
  age         String @default("")
  dateOfBirth String @default("")
  sortOrder   Int    @default(0)
  createdAt   String @default("")
  updatedAt   String @default("")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("member_children")
}

model MemberMembership {
  id        String @id @default(cuid())
  memberId  String
  year      String @default("")
  status    String @default("")
  createdAt String @default("")
  updatedAt String @default("")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, year])
  @@index([memberId])
  @@map("member_memberships")
}

model MemberPayment {
  id            String @id @default(cuid())
  memberId      String
  product       String @default("")
  amount        String @default("")
  currency      String @default("USD")
  payerName     String @default("")
  payerEmail    String @default("")
  transactionId String @default("")
  createdAt     String @default("")
  updatedAt     String @default("")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("member_payments")
}

model MemberSponsor {
  id        String @id @default(cuid())
  memberId  String
  name      String @default("")
  email     String @default("")
  phone     String @default("")
  createdAt String @default("")
  updatedAt String @default("")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("member_sponsors")
}

model RawMemberImport {
  id                      String @id @default(cuid())
  submissionId            String @default("")
  respondentId            String @default("")
  submittedAt             String @default("")
  lastModifiedAt          String @default("")
  startedAt               String @default("")
  // Member info
  firstName               String @default("")
  middleName              String @default("")
  lastName                String @default("")
  email                   String @default("")
  homePhone               String @default("")
  cellPhone               String @default("")
  qualifyingDegree        String @default("")
  nativePlace             String @default("")
  college                 String @default("")
  employer                String @default("")
  jobTitle                String @default("")
  specialInterests        String @default("")
  // Address
  street                  String @default("")
  street2                 String @default("")
  city                    String @default("")
  state                   String @default("")
  zipCode                 String @default("")
  country                 String @default("")
  // Spouse
  spouseFirstName         String @default("")
  spouseMiddleName        String @default("")
  spouseLastName          String @default("")
  spouseEmail             String @default("")
  spousePhone             String @default("")
  spouseNativePlace       String @default("")
  spouseCompany           String @default("")
  spouseCollege           String @default("")
  spouseQualifyingDegree  String @default("")
  // Children (slots 1-4)
  child1Name              String @default("")
  child1Sex               String @default("")
  child1Grade             String @default("")
  child1Age               String @default("")
  child1Dob               String @default("")
  child2Name              String @default("")
  child2Sex               String @default("")
  child2Grade             String @default("")
  child2Age               String @default("")
  child2Dob               String @default("")
  child3Name              String @default("")
  child3Sex               String @default("")
  child3Grade             String @default("")
  child3Age               String @default("")
  child3Dob               String @default("")
  child4Name              String @default("")
  child4Sex               String @default("")
  child4Grade             String @default("")
  child4Age               String @default("")
  child4Dob               String @default("")
  // Membership status per year
  lifeMember              String @default("")
  status2024              String @default("")
  status2025              String @default("")
  status2026              String @default("")
  status2027              String @default("")
  status2028              String @default("")
  status2029              String @default("")
  // Sponsor
  sponsorName             String @default("")
  sponsorEmail            String @default("")
  sponsorPhone            String @default("")
  // Payment (PayPal text)
  paypalPaymentInfo       String @default("")
  // Extra/overflow columns
  extra1                  String @default("")
  extra2                  String @default("")
  extra3                  String @default("")
  extra4                  String @default("")
  extra5                  String @default("")
  extra6                  String @default("")
  extra7                  String @default("")
  extra8                  String @default("")
  extra9                  String @default("")
  extra10                 String @default("")
  extra11                 String @default("")
  extra12                 String @default("")
  extra13                 String @default("")
  extra14                 String @default("")
  extra15                 String @default("")
  extra16                 String @default("")
  extra17                 String @default("")
  extra18                 String @default("")
  extra19                 String @default("")
  extra20                 String @default("")
  // Migration flag
  migrated                String @default("")
  createdAt               String @default("")
  updatedAt               String @default("")

  @@index([email])
  @@index([submissionId])
  @@index([migrated])
  @@map("raw_member_imports")
}

model Guest {
  id             String @id @default(cuid())
  name           String @default("")
  email          String @default("")
  phone          String @default("")
  city           String @default("")
  referredBy     String @default("")
  eventsAttended Int    @default(0)
  lastEventDate  String @default("")
  createdAt      String @default("")
  updatedAt      String @default("")

  participations EventParticipant[]

  @@index([email])
  @@map("guests")
}

model Event {
  id                  String  @id @default(cuid())
  name                String  @default("")
  date                String  @default("")
  description         String  @default("")
  status              String  @default("Upcoming")
  category            String  @default("")
  parentEventId       String  @default("")
  pricingRules        Json?
  formConfig          Json?
  activities          Json?
  activityPricingMode String  @default("")
  guestPolicy         Json?
  registrationOpen    String  @default("")
  createdAt           String  @default("")
  updatedAt           String  @default("")

  participants EventParticipant[]
  income       Income[]
  expenses     Expense[]
  sponsors     Sponsor[]

  @@index([status])
  @@index([name])
  @@map("events")
}

model EventParticipant {
  id                 String  @id @default(cuid())
  eventId            String
  type               String  @default("")
  memberId           String?
  guestId            String?
  name               String  @default("")
  email              String  @default("")
  phone              String  @default("")
  registeredAdults   String  @default("")
  registeredKids     String  @default("")
  registeredAt       String  @default("")
  actualAdults       String  @default("")
  actualKids         String  @default("")
  checkedInAt        String  @default("")
  selectedActivities Json?
  customFields       Json?
  totalPrice         String  @default("0")
  priceBreakdown     Json?
  paymentStatus      String  @default("")
  paymentMethod      String  @default("")
  transactionId      String  @default("")

  event  Event   @relation(fields: [eventId], references: [id])
  member Member? @relation(fields: [memberId], references: [id])
  guest  Guest?  @relation(fields: [guestId], references: [id])

  @@index([eventId])
  @@index([memberId])
  @@index([guestId])
  @@index([email])
  @@index([eventId, email])
  @@map("event_participants")
}

model Income {
  id            String  @id @default(cuid())
  incomeType    String  @default("Other")
  eventName     String  @default("")
  eventId       String?
  amount        Float   @default(0)
  date          String  @default("")
  paymentMethod String  @default("")
  payerName     String  @default("")
  notes         String  @default("")
  createdAt     String  @default("")
  updatedAt     String  @default("")

  event Event? @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@index([eventName])
  @@index([date])
  @@map("income")
}

model Expense {
  id                 String @id @default(cuid())
  expenseType        String @default("General")
  eventName          String @default("")
  eventId            String?
  category           String @default("Miscellaneous")
  description        String @default("")
  amount             Float  @default(0)
  date               String @default("")
  paidBy             String @default("Organization")
  receiptUrl         String @default("")
  receiptFileId      String @default("")
  notes              String @default("")
  createdAt          String @default("")
  updatedAt          String @default("")
  needsReimbursement String @default("")
  reimbStatus        String @default("")
  reimbMethod        String @default("")
  reimbAmount        Float  @default(0)
  approvedBy         String @default("")
  approvedDate       String @default("")
  reimbursedDate     String @default("")

  event Event? @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@index([eventName])
  @@index([date])
  @@map("expenses")
}

model Sponsor {
  id            String  @id @default(cuid())
  name          String  @default("")
  email         String  @default("")
  phone         String  @default("")
  type          String  @default("Annual")
  amount        Float   @default(0)
  eventName     String  @default("")
  eventId       String?
  year          String  @default("")
  paymentMethod String  @default("")
  paymentDate   String  @default("")
  status        String  @default("Pending")
  notes         String  @default("")
  createdAt     String  @default("")
  updatedAt     String  @default("")

  event Event? @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@index([eventName])
  @@index([year])
  @@index([status])
  @@map("sponsors")
}

model Transaction {
  id          String @id @default(cuid())
  externalId  String @default("")
  source      String @default("")
  amount      Float  @default(0)
  fee         Float  @default(0)
  netAmount   Float  @default(0)
  description String @default("")
  payerName   String @default("")
  payerEmail  String @default("")
  date        String @default("")
  tag         String @default("")
  eventName   String @default("")
  syncedAt    String @default("")
  notes       String @default("")

  @@index([externalId])
  @@index([date])
  @@index([eventName])
  @@map("transactions")
}

model CommitteeMember {
  email       String @id
  name        String @default("")
  designation String @default("")
  role        String @default("")
  addedAt     String @default("")
  addedBy     String @default("")
  notes       String @default("")

  @@map("committee_members")
}

model Setting {
  key       String @id
  value     String @default("")
  updatedAt String @default("")
  updatedBy String @default("")

  @@map("settings")
}

model ActivityLog {
  id            String @id @default(cuid())
  timestamp     String @default("")
  userEmail     String @default("")
  action        String @default("")
  entityType    String @default("")
  entityId      String @default("")
  entityLabel   String @default("")
  description   String @default("")
  changedFields Json?
  oldValues     Json?
  newValues     Json?

  @@index([entityType])
  @@index([userEmail])
  @@index([timestamp])
  @@map("activity_log")
}

model MembershipApplication {
  id                String @id @default(cuid())
  status            String @default("Pending")
  firstName         String @default("")
  middleName        String @default("")
  lastName          String @default("")
  email             String @default("")
  phone             String @default("")
  homePhone         String @default("")
  cellPhone         String @default("")
  qualifyingDegree  String @default("")
  nativePlace       String @default("")
  college           String @default("")
  jobTitle          String @default("")
  employer          String @default("")
  specialInterests  String @default("")
  address           Json?
  spouse            Json?
  children          Json?
  membershipType    String @default("")
  sponsorName       String @default("")
  sponsorEmail      String @default("")
  sponsorPhone      String @default("")
  amountPaid        String @default("0")
  paymentMethod     String @default("")
  transactionId     String @default("")
  paymentStatus     String @default("")
  approvals         Json?
  approvalCount     Int    @default(0)
  rejectedBy        String @default("")
  rejectedReason    String @default("")
  memberId          String @default("")
  createdAt         String @default("")
  updatedAt         String @default("")

  @@index([status])
  @@index([email])
  @@map("membership_applications")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String   @default("")
  subject   String   @default("")
  body      String   @default("") @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}

model LoginToken {
  id        String   @id @default(cuid())
  email     String
  token     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, token])
  @@map("login_tokens")
}

model SentEmail {
  id       String   @id @default(cuid())
  to       String   @default("")
  subject  String   @default("")
  body     String   @default("") @db.Text
  provider String   @default("")
  status   String   @default("")
  error    String?  @db.Text
  sentBy   String   @default("")
  sentAt   DateTime @default(now())

  @@index([provider])
  @@index([sentAt])
  @@map("sent_emails")
}
